    {
      "name": "Create a Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse JSON safely",
              "let jsonData;",
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.not.be.empty;",
              "    jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"object\");",
              "});",
              "",
              "// Keep existing extraction",
              "if (!jsonData) {",
              "    try {",
              "        jsonData = pm.response.json();",
              "    } catch (e) {",
              "        // If parsing fails, the JSON test above will already fail.",
              "    }",
              "}",
              "if (jsonData && typeof jsonData.id === \"string\") {",
              "    pm.environment.set(\"boardID\", jsonData.id);",
              "}",
              "",
              "// Status assertion",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Body shape assertions",
              "pm.test(\"Body has non-empty string properties: id, name, url\", function () {",
              "    pm.expect(jsonData, \"response JSON\").to.be.an(\"object\");",
              "",
              "    [\"id\", \"name\", \"url\"].forEach((prop) => {",
              "        pm.expect(jsonData).to.have.property(prop);",
              "        pm.expect(jsonData[prop], prop + \" should be a string\").to.be.a(\"string\");",
              "        pm.expect(jsonData[prop].trim(), prop + \" should be non-empty\").to.not.equal(\"\");",
              "    });",
              "});",
              "let createdboardname=pm.environment.get(\"boardName\");",
              "pm.test(\"Your test name\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(createdboardname);",
              "});",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let num = Math.floor(Math.random() * 1000);\r",
              "let boardName = \"myboard\" + num;\r",
              "pm.environment.set(\"boardName\", boardName);"
            ],
            "type": "text/javascript",
